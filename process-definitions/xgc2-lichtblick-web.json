{
  "apiVersion": "xgc.execution.process/v1",
  "definitions": [
    {
      "id": "lichtblick-web",
      "version": "1.3.0",
      "label": "Lichtblick WebUI",
      "description": "Pinned Lichtblick web workspace installed by xgc2-lichtblick-web and embedded through the XGC same-origin proxy.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "bridgePort": {
            "type": "integer",
            "description": "Foxglove-compatible WebSocket port on the local host",
            "default": 8765,
            "minimum": 1,
            "maximum": 65535
          },
          "port": {
            "type": "integer",
            "description": "Lichtblick HTTP port on the local host; XGC uses the dedicated loopback port 18081",
            "default": 18081,
            "minimum": 1,
            "maximum": 65535
          }
        },
        "additionalProperties": false
      },
      "resourceClaims": [
        {
          "bindingKey": "http",
          "kind": "tcp-listener",
          "mode": "",
          "capacity": 0,
          "address": "127.0.0.1",
          "portParameter": "port"
        }
      ],
      "command": {
        "executable": "/usr/bin/xgc2-lichtblick-web",
        "args": [
          "--host",
          "127.0.0.1",
          "--port",
          "${port}",
          "--control-plane-url",
          "ws://127.0.0.1:${bridgePort}",
          "--public-url-prefix",
          "/"
        ]
      },
      "readiness": {
        "kind": "tcp",
        "address": "127.0.0.1:${port}",
        "command": {"executable": ""},
        "interval": 1000000000,
        "timeout": 1000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "liveness": {
        "kind": "tcp",
        "address": "127.0.0.1:${port}",
        "command": {"executable": ""},
        "interval": 1000000000,
        "timeout": 1000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "stop": {"gracePeriod": 5000000000},
      "restart": {"mode": "never", "maxRestarts": 0, "backoff": 0},
      "digest": ""
    },
    {
      "id": "lichtblick-web",
      "version": "1.5.0",
      "label": "Lichtblick WebUI",
      "description": "Pinned Lichtblick web workspace installed by xgc2-lichtblick-web and embedded through the XGC same-origin proxy.",
      "drivers": [
        "host"
      ],
      "parameters": {
        "properties": {
          "bridgePort": {
            "type": "integer",
            "description": "Foxglove-compatible WebSocket port on the local host",
            "default": 8765,
            "minimum": 1,
            "maximum": 65535
          },
          "port": {
            "type": "integer",
            "description": "Lichtblick HTTP port on the local host; XGC uses the dedicated loopback port 18081",
            "default": 18081,
            "minimum": 1,
            "maximum": 65535
          },
          "gridVisible": {
            "type": "boolean",
            "description": "Show the grid in the run-scoped initial Lichtblick layout",
            "default": true
          },
          "arVisible": {
            "type": "boolean",
            "description": "Open the camera AR panel in the run-scoped initial Lichtblick layout",
            "default": true
          },
          "gridColor": {
            "type": "string",
            "description": "Six-digit RGB color for the initial Lichtblick grid",
            "default": "#248eff"
          },
          "gridSize": {
            "type": "number",
            "description": "Side length of the initial Lichtblick grid",
            "default": 10,
            "minimum": 0.1,
            "maximum": 100000
          },
          "gridDivisions": {
            "type": "integer",
            "description": "Subdivision count of the initial Lichtblick grid",
            "default": 10,
            "minimum": 1,
            "maximum": 10000
          },
          "gridLineWidth": {
            "type": "number",
            "description": "Line width of the initial Lichtblick grid",
            "default": 1,
            "minimum": 0.1,
            "maximum": 100
          }
        },
        "additionalProperties": false
      },
      "resourceClaims": [
        {
          "bindingKey": "http",
          "kind": "tcp-listener",
          "mode": "",
          "capacity": 0,
          "address": "127.0.0.1",
          "portParameter": "port"
        }
      ],
      "command": {
        "executable": "/usr/bin/xgc2-lichtblick-web",
        "args": [
          "--host",
          "127.0.0.1",
          "--port",
          "${port}",
          "--control-plane-url",
          "ws://127.0.0.1:${bridgePort}",
          "--public-url-prefix",
          "/",
          "--ar-visible",
          "${arVisible}",
          "--grid-visible",
          "${gridVisible}",
          "--grid-color",
          "${gridColor}",
          "--grid-size",
          "${gridSize}",
          "--grid-divisions",
          "${gridDivisions}",
          "--grid-line-width",
          "${gridLineWidth}"
        ]
      },
      "readiness": {
        "kind": "tcp",
        "address": "127.0.0.1:${port}",
        "command": {
          "executable": ""
        },
        "interval": 1000000000,
        "timeout": 1000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "liveness": {
        "kind": "tcp",
        "address": "127.0.0.1:${port}",
        "command": {
          "executable": ""
        },
        "interval": 1000000000,
        "timeout": 1000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "stop": {
        "gracePeriod": 5000000000
      },
      "restart": {
        "mode": "never",
        "maxRestarts": 0,
        "backoff": 0
      },
      "digest": ""
    }
  ]
}
