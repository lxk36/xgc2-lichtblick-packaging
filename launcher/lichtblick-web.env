# /etc/xgc2/lichtblick-web.env — defaults for xgc2-lichtblick-web
#
# This file is sourced by the launcher at start-up. Any of these can be
# overridden at the command line:
#
#   xgc2-lichtblick-web --port 9000 --control-plane-url ws://robot:8765
#
# or by setting the same variable in the calling shell's environment.
#
# Blank lines and lines starting with '#' are ignored.

# Bind address. Use 127.0.0.1 to restrict to the local machine; switch
# to 0.0.0.0 (or a specific interface IP) if you want to expose the
# UI on your LAN without a reverse proxy.
HOST=127.0.0.1

# TCP port for the HTTP server.
PORT=8080

# WebSocket upstream. Lichtblick's web bundle opens a WebSocket to fetch
# live data; we reverse-proxy that connection to whatever you put here.
#
# Default points at the XGC2 Robot Control Plane on the same host. Point
# it at any Foxglove-compatible bridge or ROS bridge by changing this:
#   ws://robot-bridge.local:8765
#   wss://bridge.example.com/foxglove
CONTROL_PLANE_URL=ws://127.0.0.1:8765

# URL prefix the bundle is served under. Default "/" exposes the UI at
# http://HOST:PORT/. Set this to "/lichtblick" if you embed the bundle
# behind an existing nginx/Caddy site that already serves other paths.
PUBLIC_URL_PREFIX=/